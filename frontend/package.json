{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:api": "openapi-generator-cli generate -i ../api/openapi.yaml -g typescript-fetch -o src/generated/api -t openapi-templates --additional-properties=typescriptThreePlus=true,withSeparateModelsAndApi=true,modelPackage=models,apiPackage=apis"
  },
  "dependencies": {
    "chordsheetjs": "^15.5.1",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.39.0",
    "@types/node": "^24.12.3",
    "@types/youtube": "^0.3.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
