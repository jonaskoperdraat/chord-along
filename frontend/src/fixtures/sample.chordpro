    E    B    D    A    G    C
D#|--0----0----0----0----0----0---|
A#|--0----0----0----0----0----0---|
F#|--9----8----11---6----4----9---|
C#|--9----9----12---7----5----10--|
G#|--7----9----12---7----5----10--|
D#|--0----7----10---5----3----8---|
{end_of_tab}
 

